# Quartus project: V1.1 LED bring-up smoke test on QMTECH EP4CGX150 core.
# Drives the 8 base-board LEDs (U9.53-60) and the 2 core-board LEDs from a
# 26-bit divider off the QMTECH 50 MHz oscillator.

set_global_assignment -name DEVICE EP4CGX150DF27I7
set_global_assignment -name FAMILY "Cyclone IV GX"
set_global_assignment -name TOP_LEVEL_ENTITY led_test
set_global_assignment -name ORIGINAL_QUARTUS_VERSION 25.1

set_global_assignment -name SYSTEMVERILOG_FILE led_test.sv
set_global_assignment -name SDC_FILE led_test.sdc

set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name STRATIX_DEVICE_IO_STANDARD "3.3-V LVCMOS"
set_global_assignment -name RESERVE_ALL_UNUSED_PINS_WEAK_PULLUP "AS INPUT TRI-STATED WITH WEAK PULL-UP"
set_global_assignment -name FITTER_EFFORT "STANDARD FIT"

# All V1.1 pin assignments — single source of truth. Pin/instance assignments
# whose net names don't appear on the led_test top are reported by Quartus
# as warnings (Info 169174 "no such pin in design") and harmlessly ignored.
set_global_assignment -name SOURCE_TCL_SCRIPT_FILE ../v1_1_pins.tcl

set_global_assignment -name LAST_QUARTUS_VERSION "25.1std.0 Lite Edition"
