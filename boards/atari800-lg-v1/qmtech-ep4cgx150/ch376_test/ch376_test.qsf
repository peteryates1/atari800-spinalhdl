# CH376T USB keyboard bridge — standalone test
# Target: EP4CGX150DF27I7 on QMTECH core board + ATARI-800-LG-V1 base board

set_global_assignment -name DEVICE EP4CGX150DF27I7
set_global_assignment -name TOP_LEVEL_ENTITY Ch376KeyboardTestTop
set_global_assignment -name FAMILY "Cyclone IV GX"
set_global_assignment -name SYSTEMVERILOG_FILE Ch376KeyboardTestTop.sv
set_global_assignment -name STRATIX_DEVICE_IO_STANDARD "3.3-V LVCMOS"
set_global_assignment -name RESERVE_ALL_UNUSED_PINS_WEAK_PULLUP "AS INPUT TRI-STATED WITH WEAK PULL-UP"
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name SDC_FILE ch376_test.sdc

# Clock
set_location_assignment PIN_B14 -to io_clk_in

# UART (CH340) — active accent accent accent for debug
set_location_assignment PIN_AF24 -to io_uart_tx
set_location_assignment PIN_AC21 -to io_uart_rx

# CH376T SPI
set_location_assignment PIN_A7  -to io_ch376_sck
set_location_assignment PIN_B6  -to io_ch376_mosi
set_location_assignment PIN_B7  -to io_ch376_miso
set_location_assignment PIN_A6  -to io_ch376_cs
set_location_assignment PIN_B11 -to io_ch376_int
set_location_assignment PIN_B10 -to io_ch376_rst
set_location_assignment PIN_C10 -to io_ch376_spi_n
set_instance_assignment -name WEAK_PULL_UP_RESISTOR ON -to io_ch376_miso
set_instance_assignment -name WEAK_PULL_UP_RESISTOR ON -to io_ch376_int

# LEDs
set_location_assignment PIN_A25 -to "io_led[0]"
set_location_assignment PIN_A24 -to "io_led[1]"

set_global_assignment -name LAST_QUARTUS_VERSION "25.1std.0 Lite Edition"
